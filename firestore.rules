rules_version = '2';

// ============================================================
// Veterinaria Leo — Firestore Security Rules (RBAC)
// ============================================================
// Roles stored in /usuarios/{uid}.roleName:
//   admin        — full read/write on all collections
//   veterinario  — write on historiales; read on clients/pets/turnos/horarios
//   recepcionista — write on clientes/mascotas/turnos; read on historiales/horarios
//   (Any authenticated user can read their own /usuarios doc)
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.roleName;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isVeterinario() {
      return isAuthenticated() && getRole() == 'veterinario';
    }

    function isRecepcionista() {
      return isAuthenticated() && getRole() == 'recepcionista';
    }

    function isPeluquero() {
      return isAuthenticated() && getRole() == 'peluquero';
    }

    // ── /usuarios ─────────────────────────────────────────
    // Admins leen/escriben todos los docs de usuario.
    // Cualquier usuario autenticado lee y edita su propio doc, pero SIN escalar
    // privilegios.
    //
    // OWNER_EMAIL: email del dueño del sistema. DEBE coincidir con la constante
    // OWNER_EMAIL de AuthContext.tsx (se usa para el bootstrap del primer admin).
    match /usuarios/{userId} {
      allow read:   if isAuthenticated() && (isAdmin() || request.auth.uid == userId);

      // Crear: solo un admin.
      // BOOTSTRAP del primer admin: el dueño puede crear SU PROPIO doc como admin
      // (su email lo verifica Firebase Auth, así ningún otro usuario puede hacerlo).
      allow create: if isAdmin()
                    || (
                         request.auth.uid == userId
                         && request.auth.token.email == 'mateob7505@gmail.com'
                         && request.resource.data.roleName == 'admin'
                       );

      // Actualizar: el admin puede todo. El propio usuario puede editar su perfil
      // (nombre, teléfono, etc.) pero NO puede escalar privilegios: roleName,
      // roleId, permissions y active quedan bloqueados salvo que sea admin.
      allow update: if isAdmin()
                    || (
                         request.auth.uid == userId
                         && !request.resource.data.diff(resource.data).affectedKeys()
                              .hasAny(['roleName', 'roleId', 'permissions', 'active'])
                       );

      allow delete: if isAdmin();
    }

    // ── /clientes ─────────────────────────────────────────
    // Admin + recepcionista: full R/W
    // Veterinario: read-only
    // Peluquero: read-only
    match /clientes/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin() || isRecepcionista();
    }

    // ── /mascotas ─────────────────────────────────────────
    // Admin + recepcionista: full R/W
    // Veterinario: read-only
    // Peluquero: read-only
    match /mascotas/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin() || isRecepcionista();
    }

    // ── /historiales ──────────────────────────────────────
    // Admin + veterinario: full R/W
    // Recepcionista + peluquero: read-only
    match /historiales/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin() || isVeterinario();
    }

    // ── /turnos ───────────────────────────────────────────
    // Admin + recepcionista + veterinario + peluquero: crear/actualizar
    // (All authenticated staff can manage appointments)
    // Borrado físico: solo admin (la cancelación es un update de status).
    match /turnos/{docId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── /slots ────────────────────────────────────────────
    // Lock de unicidad de horario por profesional. ID determinista:
    // {doctorId}_{YYYY-MM-DD}_{HH:mm}. Se crea en el MISMO writeBatch que el
    // turno; `update: if false` hace que un batch.set sobre un slot existente
    // falle (Firestore lo evalúa como update) y aborte el batch entero →
    // imposible la doble reserva, sin Cloud Functions.
    match /slots/{slotId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated();
    }

    // ── /horarios ─────────────────────────────────────────
    // Admin: full R/W
    // All other roles: read-only (they need to see schedules)
    match /horarios/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
    }

    // ── /auditoria ────────────────────────────────────────
    // Admin: read-only (audit logs should not be modified)
    // Crear: solo con el userId del propio autenticado (no se puede
    // suplantar a otro usuario en el log). Append-only.
    match /auditoria/{docId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── /especies ─────────────────────────────────────────
    // All authenticated users read; only admin writes
    match /especies/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
    }

    // ── /razas ────────────────────────────────────────────
    // All authenticated users read; only admin writes
    match /razas/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
    }

    // ── /tiposEvento ──────────────────────────────────────
    // All authenticated users read; only admin writes
    match /tiposEvento/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
    }

    // ── /tiposServicio ────────────────────────────────────
    // All authenticated users read; only admin writes
    match /tiposServicio/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
    }

    // ── /arbolVacunacion ──────────────────────────────────
    // All authenticated users read; only admin writes
    match /arbolVacunacion/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
    }

    // ── /profesiones ──────────────────────────────────────
    // All authenticated users read (needed for user creation combo)
    // Only admin writes
    match /profesiones/{docId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
    }

    // ── /doctores ─────────────────────────────────────────
    // All authenticated users read (needed to populate selects)
    // Admin: full R/W; veterinarios/peluqueros can update their own profile
    match /doctores/{docId} {
      allow read:   if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── /email_logs ───────────────────────────────────────
    // Log de correos enviados vía Resend (resendService.ts).
    // Crear: solo con el userId del propio autenticado. Leer: solo admin.
    // Nunca se modifican ni se borran (integridad del log).
    match /email_logs/{docId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── Deny everything else ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
