# Variables de entorno para Veterinaria Leo
# Copia este archivo a ".env" localmente si deseas probar, 
# pero Vercel requiere que se configuren en su dashboard.

# API Key de Resend (No debe ser expuesta en el frontend si es posible,
# pero al ser vite, se usa VITE_ si se lee desde React.
# En este caso, la funcion serverless lee process.env.RESEND_API_KEY)
RESEND_API_KEY=re_ejemplo123456789

# Opcional: Correo desde donde se envían (Debe ser un dominio verificado en Resend)
# Por defecto el código usa: Veterinaria Leo <notificaciones@notificationvet.com>
EMAIL_FROM="Veterinaria Leo <notificaciones@notificationvet.com>"
