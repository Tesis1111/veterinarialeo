# ============================================================
# Veterinaria Leo — Variables de Entorno para Firebase
# ============================================================
#
# 1. Copia este archivo: cp env.example .env.local
# 2. Rellena los valores con los datos de tu proyecto Firebase:
#    Firebase Console → Configuración del proyecto ⚙️ → Tus apps → Web
# 3. En Vercel: Settings → Environment Variables → agrega cada clave
#
# IMPORTANTE: El prefijo VITE_ es obligatorio para que Vite exponga
# la variable al código del navegador. Sin él, el valor será undefined.
# ============================================================

# ── Firebase Web SDK ──────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:XXXXXXXXXXXXXXXXXXXXXXXX

# ── Opcional ──────────────────────────────────────────────────────────────────
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX   ← Analytics (opcional)

# ── Notas de seguridad ────────────────────────────────────────────────────────
# Estas claves se incluyen en el bundle del cliente (son públicas por diseño).
# La seguridad real la proveen Firestore Rules + Firebase Auth.
# NUNCA agregues claves privadas del Firebase Admin SDK aquí.
# El archivo .env.local está excluido del repositorio vía .gitignore (.env*).
